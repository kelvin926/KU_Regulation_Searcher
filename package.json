{
  "name": "ku-regulation-searcher",
  "version": "0.9.2",
  "description": "고려대학교 규정 로컬 검색 및 Gemini RAG Windows 앱",
  "author": "kelvin926",
  "license": "SEE LICENSE IN README.md",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run rebuild:electron && concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 6127 --strictPort",
    "dev:main": "tsc -w -p tsconfig.main.json",
    "dev:electron": "wait-on http://127.0.0.1:6127 dist/main/index.js dist/preload/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:6127 electron .",
    "typecheck": "tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.main.json",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.main.json",
    "test": "npm rebuild better-sqlite3 && vitest run",
    "eval:local-search": "npm rebuild better-sqlite3 && npm run build && node scripts/evaluate-local-search.cjs",
    "eval:local-search:complex": "npm rebuild better-sqlite3 && npm run build && node scripts/evaluate-local-search.cjs --style complex --count 10000 --minPassRate 0.999",
    "dist:win": "npm run build && npm run rebuild:electron && electron-builder --win dir --x64 --publish never && npm run win:icon && electron-builder --win nsis --x64 --prepackaged release/win-unpacked --publish never",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "win:icon": "node scripts/apply-win-icon.cjs"
  },
  "dependencies": {
    "@google/genai": "^1.31.0",
    "better-sqlite3": "^12.5.0",
    "cheerio": "^1.1.2",
    "lucide-react": "^0.554.0",
    "pretendard": "^1.3.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.3",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.13",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "kr.ac.korea.regulation.assistant",
    "productName": "KU Regulation Searcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "KU-Regulation-Setup-0.9.2.${ext}"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "KU Regulation Searcher"
    }
  }
}
